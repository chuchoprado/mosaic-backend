# ============================================================
# Mosaic Backend — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# ─── Server ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Base URL of the backend (used for presigned URL generation, webhooks)
API_BASE_URL=http://localhost:3000

# ─── Supabase ────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase JWT secret — used to verify tokens issued by Supabase Auth
# Found in: Supabase Dashboard → Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Direct PostgreSQL connection string (for migrations and direct queries)
# Found in: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ─── Redis ──────────────────────────────────────────────────
# Railway Redis plugin provides REDIS_URL automatically
REDIS_URL=redis://localhost:6379

# Redis key prefix to avoid collisions in shared instances
REDIS_KEY_PREFIX=mosaic:

# ─── Agent JWT ───────────────────────────────────────────────
# RS256 key pair for signing agent tokens (not Supabase Auth)
# Generate with:
#   openssl genrsa -out agent_private.pem 2048
#   openssl rsa -in agent_private.pem -pubout -out agent_public.pem
AGENT_JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
AGENT_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Agent token expiry (e.g., "30d")
AGENT_JWT_EXPIRY=30d

# ─── Cloudflare R2 ──────────────────────────────────────────
# Found in: Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=mosaic-evidence
R2_PUBLIC_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Presigned URL expiry in seconds (1 hour = 3600)
R2_PRESIGNED_UPLOAD_EXPIRY=900
R2_PRESIGNED_GET_EXPIRY=3600

# ─── Firebase Cloud Messaging ────────────────────────────────
# Firebase Admin SDK service account JSON
# Found in: Firebase Console → Project Settings → Service Accounts
# Paste the entire JSON as a single-line string (escape quotes)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Rate Limiting ───────────────────────────────────────────
# Max requests per window for standard API endpoints
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Stricter limit for auth endpoints
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# ─── Session / Lock ─────────────────────────────────────────
# How often (seconds) agents should poll for state changes
AGENT_POLL_INTERVAL_SECONDS=30

# How long (minutes) an agent is considered offline after missing heartbeats
AGENT_OFFLINE_THRESHOLD_MINUTES=5

# Max seconds before a Redis session key expires (safety ceiling: 24h)
MAX_SESSION_DURATION_SECONDS=86400

# ─── Logging ─────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Pretty-print logs in development (set to false in production)
LOG_PRETTY=true
